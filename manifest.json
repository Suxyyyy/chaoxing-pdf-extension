{
  "manifest_version": 3,
  "name": "Chaoxing PDF Link Extractor",
  "version": "0.2.0",
  "description": "在学习通课件页一键提取课件的 PDF 文件链接。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://mooc1.chaoxing.com/*",
    "https://s3.ananas.chaoxing.com/*"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://mooc1.chaoxing.com/mycourse/studentstudy*",
        "https://mooc1.chaoxing.com/mooc-ans/knowledge/cards*",
        "https://mooc1.chaoxing.com/mooc-ans/screen/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
